# english-talk — szablon zmiennych środowiskowych
# Wartości NIGDY nie trafiają do repo.
# Zdalne (Vercel):  vercel env pull .env.vercel   (inspekcja; NIE nadpisywać .env.local)
# Lokalny dev:      .env.local wskazuje lokalny stack Supabase (npx supabase start)
# Produkcja:        vercel env add <NAZWA> production

# --- OpenAI (Realtime voice: mint tokenów client_secrets + analiza transkryptu; server-only) ---
# Wchodzi do Vercela dopiero po ustawieniu bezpieczników OpenAI (przedpłata, auto-recharge OFF).
OPENAI_API_KEY=

# --- Supabase (sprovisionowane 2026-07-15 przez Vercel Marketplace, zasób supabase-cordovan-kettle,
# --- region eu-central-1; auto-synchronizowane do Production/Preview/Development) ---
# Postgres (connection stringi; server-only):
# POSTGRES_URL=                  # pooled
# POSTGRES_PRISMA_URL=
# POSTGRES_URL_NON_POOLING=      # do migracji
# POSTGRES_HOST=
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_DATABASE=
# API Supabase — wymagane przez runtime (auth: klient serwerowy + proxy):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Lokalny stack: jeśli `npx supabase start` wypisuje tylko legacy "anon key",
# wpisz tę wartość jako NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY w .env.local
# (nazwa zmiennej to kontrakt kodu; wartości są wymienne).
# Pozostałe warianty (auto-provisionowane na Vercelu, nieużywane przez kod):
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_PUBLISHABLE_KEY=
# Server-only — NIGDY w kodzie klienta ani pod prefiksem NEXT_PUBLIC_:
# SUPABASE_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET=

# --- Google OAuth (WYŁĄCZNIE lokalny stack — podstawiane do supabase/config.toml
# --- przez env() przy `supabase start`; zdalny projekt konfigurowany w Supabase Dashboard) ---
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
